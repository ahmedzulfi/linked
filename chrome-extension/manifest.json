{
  "manifest_version": 3,
  "name": "Webild Assistant",
  "version": "1.0",
  "description": "Generate a beautiful portfolio website instantly from your logged-in LinkedIn profile.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://linkedpage.io/*",
        "https://*.linkedpage.io/*"
      ],
      "js": ["receiver.js"],
      "run_at": "document_start"
    }
  ]
}
